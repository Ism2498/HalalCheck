{
  "manifest_version": 3,
  "name": "HalalCheck",
  "version": "1.0",
  "description": "Instantly check if a food product is Halal, Kosher, or neither using AI",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://api.groq.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
